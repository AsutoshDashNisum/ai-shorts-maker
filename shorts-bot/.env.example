# ─────────────────────────────────────────────────────
#  shorts-bot  ·  Environment Variables
#  Copy this file → .env and fill in real values
# ─────────────────────────────────────────────────────

# YouTube OAuth  (download from Google Cloud Console)
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Processing settings
OUTPUT_DIR=./output
NUM_CLIPS=5
MAX_CLIP_DURATION=59

# Retry settings (optional tweaking)
MAX_RETRIES=3
RETRY_BASE_DELAY=2.0
